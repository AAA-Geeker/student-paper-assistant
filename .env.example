# ============================================================================
# 学生论文写作助手 — 生产环境变量模板
# 复制此文件为 .env 并填入实际值
# 生成密钥: openssl rand -hex 32
# ============================================================================

# ─── 安全（必须修改！）──────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-secret-key
POSTGRES_PASSWORD=change-me-to-a-random-db-password

# ─── 数据库 ────────────────────────────────────────────────────────────────
# SQLite 模式（单容器部署，简单但数据在容器内）
# DATABASE_URL=sqlite:////app/data/app.db
# PostgreSQL 模式（多容器部署，推荐生产环境）
DATABASE_URL=postgresql://paper:YOUR_DB_PASSWORD@db/paper

# ─── 默认 LLM（兼容 OpenAI 格式）───────────────────────────────────────────
LLM_API_KEY=sk-your-openai-api-key
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=4096

# ─── 多模型 API Keys（按需配置，至少填一个）────────────────────────────────
# DeepSeek：便宜、速度快，适合大纲生成和初稿起草
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# Anthropic Claude：适合需要深度推理的步骤（审查、答辩准备）
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ─── 额度控制 ──────────────────────────────────────────────────────────────
MONTHLY_BUDGET_USD=10.0
WARN_AT_PERCENT=80
AUTO_DOWNGRADE=true
DEFAULT_TIER=budget

# ─── 上下文控制 ────────────────────────────────────────────────────────────
MAX_CONTEXT_TOKENS=8000
SEGMENT_POLISH_SIZE=500

# ─── 令牌过期时间（分钟）────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=1440
